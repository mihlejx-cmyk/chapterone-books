generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}
enum BookFormat {
  PHYSICAL
  DIGITAL
}
enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

model User {
  id             String           @id @default(uuid())
  supabaseUserId String           @unique
  email          String           @unique
  name           String?
  role           UserRole         @default(CUSTOMER)
  avatarUrl      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  orders         Order[]
  reviews        Review[]
  wishlistItems  WishlistItem[]
  addresses      Address[]
  recentlyViewed RecentlyViewed[]
}

model Author {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  bio         String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  books       Book[]
}

model Category {
  id          String         @id @default(uuid())
  name        String         @unique
  slug        String         @unique
  description String?
  books       BookCategory[]
}

model Book {
  id            String           @id @default(uuid())
  slug          String           @unique
  title         String
  isbn          String           @unique
  description   String
  publisher     String
  publishedAt   DateTime
  language      String           @default("English")
  pages         Int
  format        BookFormat       @default(PHYSICAL)
  priceCents    Int
  salePriceCents Int?
  coverUrl      String
  previewImages String[]
  sampleUrl     String?
  rating        Decimal          @default(0) @db.Decimal(2, 1)
  reviewCount   Int              @default(0)
  isFeatured    Boolean          @default(false)
  isStaffPick   Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  authorId      String
  author        Author           @relation(fields: [authorId], references: [id])
  categories    BookCategory[]
  inventory     Inventory?
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  recentlyViewed RecentlyViewed[]
  relatedFrom   RelatedBook[]    @relation("relatedFrom")
  relatedTo     RelatedBook[]    @relation("relatedTo")
  @@index([title])
  @@index([authorId])
  @@index([publishedAt])
  @@index([priceCents])
}

model BookCategory {
  bookId     String
  categoryId String
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@id([bookId, categoryId])
}

model RelatedBook {
  bookId        String
  relatedBookId String
  book          Book @relation("relatedFrom", fields: [bookId], references: [id], onDelete: Cascade)
  relatedBook   Book @relation("relatedTo", fields: [relatedBookId], references: [id], onDelete: Cascade)
  @@id([bookId, relatedBookId])
}

model Inventory {
  id          String   @id @default(uuid())
  bookId      String   @unique
  quantity    Int      @default(0)
  reorderAt   Int      @default(5)
  updatedAt   DateTime @updatedAt
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  @@index([quantity])
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  userId          String?
  email           String
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  stripeSessionId String?       @unique
  subtotalCents   Int
  shippingCents   Int
  taxCents        Int
  totalCents      Int
  shippingAddress Json?
  billingAddress  Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User?         @relation(fields: [userId], references: [id])
  items           OrderItem[]
  @@index([userId, createdAt])
  @@index([status])
}

model OrderItem {
  id         String @id @default(uuid())
  orderId    String
  bookId     String
  title      String
  unitCents  Int
  quantity   Int
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book       Book   @relation(fields: [bookId], references: [id])
  @@index([bookId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  bookId    String
  rating    Int
  title     String?
  body      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  @@unique([userId, bookId])
  @@index([bookId, approved])
}

model WishlistItem {
  userId    String
  bookId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  @@id([userId, bookId])
}

model Address {
  id         String   @id @default(uuid())
  userId     String
  label      String
  firstName  String
  lastName   String
  line1      String
  line2      String?
  city       String
  province   String
  postalCode String
  country    String   @default("South Africa")
  isDefault  Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model RecentlyViewed {
  userId    String
  bookId    String
  viewedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  @@id([userId, bookId])
  @@index([userId, viewedAt])
}

model Coupon {
  id             String   @id @default(uuid())
  code           String   @unique
  percentOff     Int?
  amountOffCents Int?
  usageLimit     Int?
  usedCount      Int      @default(0)
  expiresAt      DateTime?
  active         Boolean  @default(true)
}

model BlogPost {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  excerpt     String
  body        String
  coverUrl    String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([publishedAt])
}

model NewsletterSubscriber {
  id          String   @id @default(uuid())
  email       String   @unique
  subscribedAt DateTime @default(now())
  confirmedAt DateTime?
  source      String?
}
